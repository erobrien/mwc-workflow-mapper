# secrets — never commit; copy secrets.json between machines manually
secrets.json
audit/.token

# dependencies / build output
node_modules/
mwc-asis/dist/
plan-workspace/dist/

# machine-local runtime output (regenerated; keep history per-machine)
monitor/data/
monitor/reports/
audit/daily/
audit/snapshots/

# raw workflow builder captures (3MB+, regenerable via capture_workflows.py;
# the derived tag_workflow_refs.json is committed instead)
ghl_data/workflow_defs/

# vercel local link metadata
.vercel/
diff-site/.vercel/

# misc
*.pyc
__pycache__/

# Attribution audit: raw contact/opportunity samples contain PII/PHI-adjacent
# data (names, emails, phones, IPs) -- never commit them. Only the aggregated,
# de-identified attribution_report.json/custom_fields_all.json/objects_all.json
# are safe to keep.
ghl_data/attribution/contacts_sample.json
ghl_data/attribution/opportunities_sample.json
ghl_data/attribution/overwrite_examples.json
