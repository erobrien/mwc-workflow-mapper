    "conditions": [],
    "html": "<p style=\"margin:0px; padding-left: 0px!important;margin: 0px;\">Hi {{contact.first_name}},</p><br/><br/><p style=\"margin:0px; padding-left: 0px!important;margin: 0px;\" class=\"isSelectedEnd\">It’s been a while since you last visited Men’s Wellness Center, so we just wanted to check in.</p><br/><p style=\"margin:0px; padding-left: 0px!important;margin: 0px;\" class=\"isSelectedEnd\">If you’re still experiencing symptoms or have questions about your health, a confidential consultation can help you understand your options — no pressure, no obligation.</p><br/><p style=\"margin:0px; padding-left: 0px!important;margin: 0px;\" class=\"isSelectedEnd\">If you’d like to schedule an appointment, you can do so anytime here:<br><a target=\"_blank\" rel=\"noopener noreferrer nofollow\" href=\"https://menswellnesscenters.com/book-a-consultation/\"><strong>Schedule Your Appointment</strong></a></p><br/><p style=\"margin:0px; padding-left: 0px!important;margin: 0px;\" class=\"isSelectedEnd\">And if now isn’t the right time, that’s completely okay. We’re here whenever you’re ready.</p><br/><br/><p style=\"margin:0px; padding-left: 0px!important;margin: 0px;\">Best,<br><strong>Men’s Wellness Center</strong></p>",
    "from_name": "Men's Wellness Center",
    "from_email": "{{location.email}}",
    "subject": "Checking in. Questions on how we can help?",
