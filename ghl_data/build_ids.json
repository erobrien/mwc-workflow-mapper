    "update_metadata": "PUT /workflow/{locationId}/{workflowId}  body must include current version int  [PROVEN]",
    "save_steps": "PUT /workflow/{loc}/{id} with FULL workflow doc from GET, then set workflowData={'templates':[...]} AND top-level templates=[...] AND createdSteps/modifiedSteps/deletedSteps diff arrays. Must include current version int. Read back via fileUrl. [PROVEN 2026-07-11]",
    "read_trigger": "GET /workflow/{locationId}/trigger?workflowId=...  [PROVEN]",
    "write_trigger": "POST /workflow/{locationId}/trigger  body {workflowId, type (REQUIRED), name, conditions[], actions[], masterType:'highlevel', belongs_to:'workflow'} -> {id}  [PROVEN 2026-07-11]",
    "update_trigger": "PUT /workflow/{locationId}/trigger/{triggerId}  full trigger object -> success  [PROVEN 2026-07-11]",
    "node_notes": "wait.attributes.startAfter.type must be hour|day (NOT minute - rejected). Node ids are uuids; chain via 'next'. if_else uses attributes.branches[].segments[].conditions[] with conditionType/conditionSubType(fieldId)/conditionOperator/conditionValue.",
    "if_else": "if_else node PROVEN 2026-07-11: attributes.branches[].segments[].conditions[] with conditionType:'opportunity', conditionSubType:<fieldId>, conditionOperator (==, is_any_of), conditionValue. Branch children link via parent+parentKey=branch.id. Validated against opportunity.appt_status on live.",
    "opportunity_write": "internal_create_opportunity node PROVEN 2026-07-11: attributes {pipelineId, type:'internal_create_opportunity', __customInputFields__:[{value,filterField,valueFieldType}], __customInputs__:{}}. filterField = pipelineStageId | status | name | custom_fields.<fieldId>. Writes/updates the opportunity incl. custom-field values."
  },
